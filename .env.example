# ==========================================================
# Providers
# ==========================================================

LLM_PROVIDER=ollama

# ==========================================================
# Ollama Connection
# ==========================================================

# Use host.docker.internal when running inside Docker (compose.yaml default).
# Use localhost:11434 when running the app directly on your machine.
OLLAMA_HOST=http://host.docker.internal:11434

# ==========================================================
# Ollama Models
# ==========================================================

OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_VLM_MODEL=qwen2.5vl:7b

# ==========================================================
# Embeddings
# ==========================================================

# sentence-transformers models (contain '/') download from HuggingFace automatically.
# Ollama embedding models (e.g. nomic-embed-text) require: ollama pull nomic-embed-text
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ==========================================================
# CLIP
# ==========================================================

CLIP_MODEL=ViT-B-32

# ==========================================================
# Retrieval
# ==========================================================

VECTOR_STORE=faiss

TOP_K=5

# ==========================================================
# Chunking
# ==========================================================

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ==========================================================
# API Keys (optional)
# ==========================================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
HF_TOKEN=

# ==========================================================
# Qdrant
# ==========================================================

QDRANT_URL=
QDRANT_API_KEY=