# ==========================================================
# Providers
# ==========================================================

LLM_PROVIDER=ollama

# ==========================================================
# Ollama Models
# ==========================================================

OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_VLM_MODEL=qwen2.5vl:7b

# ==========================================================
# Embeddings
# ==========================================================

EMBEDDING_MODEL=nomic-embed-text

# ==========================================================
# CLIP
# ==========================================================

CLIP_MODEL=ViT-B-32

# ==========================================================
# Retrieval
# ==========================================================

VECTOR_STORE=faiss

TOP_K=5

# ==========================================================
# Chunking
# ==========================================================

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ==========================================================
# API Keys (optional)
# ==========================================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
HF_TOKEN=

# ==========================================================
# Qdrant
# ==========================================================

QDRANT_URL=
QDRANT_API_KEY=